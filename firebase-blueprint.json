{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ImageEdit": {
      "title": "Image Edit",
      "description": "An image edited by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "prompt": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "imageUrl", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/edits/{editId}": {
      "schema": { "$ref": "#/entities/ImageEdit" },
      "description": "User's edited images"
    }
  }
}
